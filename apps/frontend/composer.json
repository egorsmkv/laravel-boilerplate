{
  "name": "egorsmkv/laravel-boilerplate",
  "version": "1.0.0",
  "type": "project",
  "description": "A Laravel Boilerplate with Batteries on Modern Technologies.",
  "keywords": [
    "app"
  ],
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-zmq": "*",
    "guzzlehttp/guzzle": "^7.10",
    "laravel-lang/locales": "^2.10",
    "laravel/framework": "^12.52",
    "laravel/horizon": "^5.44",
    "laravel/octane": "^2.14.0",
    "league/flysystem-aws-s3-v3": "^3.31",
    "nyholm/psr7": "^1.8.2",
    "sentry/sentry-laravel": "^4.20.1",
    "spiral/roadrunner-cli": "^2.7.2",
    "spiral/roadrunner-http": "^4.1"
  },
  "require-dev": {
    "carthage-software/mago": "^1.13.2@rc",
    "fakerphp/faker": "^1.24.1",
    "larastan/larastan": "^3.9.3",
    "laravel-lang/common": "^6.7.2",
    "laravel/telescope": "^5.18",
    "maantje/xhprof-buggregator-laravel": "^0.7",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.1",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpunit/phpunit": "^12.5.14",
    "spatie/laravel-ignition": "^2.11",
    "spaze/phpstan-disallowed-calls": "^4.8",
    "symfony/var-dumper": "^7.4.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": [
        "laravel/telescope"
      ]
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "carthage-software/mago": true,
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    },
    "platform": {
      "php": "8.3.6"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
